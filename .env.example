NODE_ENV=development
PORT=5000

# Database URL (PostgreSQL)
# For Supabase: Use pooler URL for runtime queries
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/vehixa
# For Supabase: Use direct URL for migrations (required for pgBouncer pooler)
DIRECT_URL=postgresql://USER:PASSWORD@localhost:5432/vehixa

# JWT Authentication
JWT_SECRET=your-super-secret-key
JWT_EXPIRES_IN=7d

# API Configuration
API_PREFIX=/api/v1

# ML Model Configuration
ML_MODEL_VERSION=vehixa-heuristic-v1
