// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum Role {
  USER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID
  CNG
  LPG
  HYDROGEN
}

enum EngineType {
  INLINE
  V_TYPE
  BOXER
  ROTARY
  ELECTRIC_MOTOR
}

enum VehicleType {
  SEDAN
  HATCHBACK
  SUV
  COUPE
  CONVERTIBLE
  WAGON
  MINIVAN

  MOTORCYCLE
  SCOOTER

  PICKUP_TRUCK
  LIGHT_TRUCK
  HEAVY_TRUCK
  TRAILER
  BUS
  SCHOOL_BUS
  DELIVERY_VAN

  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID

  CONSTRUCTION
  AGRICULTURAL
  EMERGENCY
  MILITARY

  FLEET_VEHICLE
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  SEVERE
}

enum ActionType {
  INSPECT
  REPLACE
  SERVICE
  MONITOR
  CALIBRATE
  UPDATE_SOFTWARE
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum HealthStatus {
  HEALTHY
  WARNING
  CRITICAL
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TelemetrySource {
  MANUAL_ENTRY
  SIMULATOR
  OBD_DEVICE
  API_PUSH
  DIGITAL_TWIN
}

enum VehicleOperationalStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DECOMMISSIONED
}

// Models

model User {
  userId    String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle[]
  alerts  Alert[]

  @@index([email])
}

model Vehicle {
  vehicleId        String                   @id @default(uuid())
  userId           String
  vehicleNumber    String?                  @unique
  model            String?
  manufacturer     String?
  year             Int?
  vehicleType      VehicleType?
  vin              String?                  @unique
  engineType       EngineType?
  fuelType         FuelType
  registrationDate DateTime?
  status           VehicleOperationalStatus @default(ACTIVE)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  user          User               @relation(fields: [userId], references: [userId], onDelete: Cascade)
  telemetry     Telemetry[]
  healthRecords HealthPrediction[]
  alerts        Alert[]

  @@index([userId])
}

model Telemetry {
  telemetryId        String           @id @default(uuid())
  vehicleId          String
  source             TelemetrySource?
  engineTemp         Float?
  batteryVoltage     Float?
  rpm                Int?
  oilPressure        Float?
  mileage            Float?
  vibrationLevel     Float?
  fuelEfficiency     Float?
  errorCodesCount    Int?
  ambientTemperature Float?
  coolantLevel       Float?
  recordedAt         DateTime
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  vehicle          Vehicle           @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)
  healthPrediction HealthPrediction?

  @@index([vehicleId, recordedAt])
}

model HealthPrediction {
  predictionId         String       @id @default(uuid())
  vehicleId            String
  telemetryId          String       @unique
  healthScore          Float
  status               HealthStatus
  failureProbability   Float?
  riskLevel            RiskLevel?
  predictedFailureDays Int?
  confidenceScore      Float?
  modelVersion         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle         Vehicle          @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)
  telemetry       Telemetry        @relation(fields: [telemetryId], references: [telemetryId], onDelete: Cascade)
  alerts          Alert[]
  recommendations Recommendation[]

  @@index([vehicleId])
  @@index([status])
}

model Recommendation {
  recommendationId String                  @id @default(uuid())
  predictionId     String
  title            String?
  description      String?
  priority         RecommendationPriority?
  actionType       ActionType?
  actionDueDays    Int?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  healthPrediction HealthPrediction @relation(fields: [predictionId], references: [predictionId], onDelete: Cascade)

  @@index([predictionId])
}

model Alert {
  alertId      String        @id @default(uuid())
  vehicleId    String
  predictionId String
  alertType    String?
  severity     AlertSeverity
  title        String
  message      String
  isResolved   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  vehicle          Vehicle          @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)
  healthPrediction HealthPrediction @relation(fields: [predictionId], references: [predictionId], onDelete: Cascade)
  user             User?            @relation(fields: [userUserId], references: [userId])
  userUserId       String?

  @@index([vehicleId])
  @@index([severity])
}

model ModelMetadata {
  id                  String    @id @default(uuid())
  version             String    @unique
  algorithm           String?
  accuracy            Float?
  precisionScore      Float?
  recallScore         Float?
  f1Score             Float?
  trainingDatasetSize Int?
  featuresUsed        String?
  trainedOn           DateTime?

  createdAt DateTime @default(now())
}
